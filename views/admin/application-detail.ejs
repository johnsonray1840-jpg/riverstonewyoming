<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/meta') %>
    <title>Application Details | Admin | River Stone Wyoming</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .detail-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-bottom: 30px; }
        .detail-section { background: var(--card-bg); border: 1px solid var(--glass-border); border-radius: 12px; padding: 20px; }
        .detail-section.full-width { grid-column: span 2; }
        .detail-section h3 { margin-bottom: 15px; font-size: 1.1rem; }
        .detail-table { width: 100%; }
        .detail-table th { text-align: left; width: 40%; color: var(--gray-light); font-weight: 500; padding: 8px 0; }
        .detail-table td { padding: 8px 0; }
        .document-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-top: 15px; }
        .document-card { background: var(--glass-bg); border-radius: 8px; overflow: hidden; }
        .document-card img, .document-card embed { width: 100%; height: 200px; object-fit: cover; display: block; }
        .doc-label { padding: 10px; text-align: center; font-size: 0.9rem; color: var(--gray-light); }
        .action-bar { display: flex; gap: 15px; margin: 30px 0; flex-wrap: wrap; }
        .admin-notes { background: rgba(239,68,68,0.05); border: 1px dashed var(--danger); padding: 15px; border-radius: 8px; margin-top: 20px; }
        .badge-pending { background: rgba(245,158,11,0.2); color: var(--warning); }
        .badge-approved { background: rgba(16,185,129,0.2); color: var(--success); }
        .badge-rejected { background: rgba(239,68,68,0.2); color: var(--danger); }
        .badge-paid { background: rgba(16,185,129,0.2); color: var(--success); }
        .modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 10000; }
        .modal-content { background: var(--secondary); padding: 30px; border-radius: 16px; max-width: 500px; width: 90%; }
        .modal-actions { display: flex; gap: 10px; margin-top: 20px; justify-content: flex-end; }
        @media (max-width: 768px) { .detail-grid { grid-template-columns: 1fr; } .detail-section.full-width { grid-column: span 1; } }
    </style>
</head>
<body>
    <%- include('../partials/header-admin') %>

    <div class="dashboard">
        <div class="container">
            <div class="dashboard-grid">
                <div class="sidebar">
                    <ul class="sidebar-nav">
                        <li><a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                        <li><a href="/admin/kyc"><i class="fas fa-id-card"></i> KYC Verification</a></li>
                        <li><a href="/admin/plans"><i class="fas fa-box"></i> Plans Management</a></li>
                        <li class="active"><a href="/admin/applications"><i class="fas fa-file-alt"></i> LLC Applications</a></li>
                        <li>
                            <a href="/admin/withdrawals">
                                <i class="fas fa-money-bill-wave"></i> 
                                Withdrawals
                            </a>
                        </li>
                        <li><a href="/admin/wallet-pool"><i class="fas fa-wallet"></i> Wallet Pool</a></li>
                        <li><a href="/admin/users"><i class="fas fa-users"></i> Users</a></li>
                    </ul>
                </div>

                <div class="content-area">
                    <div class="dashboard-header">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <div>
                                <h1>Application Details</h1>
                                <p><a href="/admin/applications"><i class="fas fa-arrow-left"></i> Back to Applications</a></p>
                            </div>
                            <div>
                                <span class="badge badge-<%= application.status %>" style="font-size:1rem;"><%= application.status %></span>
                            </div>
                        </div>
                    </div>

                    <div class="detail-grid">
                        <!-- Applicant Information -->
                        <div class="detail-section">
                            <h3><i class="fas fa-user"></i> Applicant Information</h3>
                            <table class="detail-table">
                                <tr><th>Name</th><td><%= application.userId?.fullName || 'N/A' %></td></tr>
                                <tr><th>Email</th><td><%= application.userId?.email || 'N/A' %></td></tr>
                                <tr><th>Phone</th><td><%= application.userId?.phone || 'Not provided' %></td></tr>
                                <tr><th>Address</th><td>
                                    <% if (application.userId?.address) { %>
                                        <%= application.userId.address.street %>, <%= application.userId.address.city %>, <%= application.userId.address.state %> <%= application.userId.address.zipCode %>
                                    <% } else { %>Not provided<% } %>
                                </td></tr>
                            </table>
                        </div>

                        <!-- LLC Details -->
                        <div class="detail-section">
                            <h3><i class="fas fa-building"></i> LLC Information</h3>
                            <table class="detail-table">
                                <tr><th>Desired LLC Name</th><td><strong><%= application.desiredLLCName %></strong></td></tr>
                                <tr><th>Alternative 1</th><td><%= application.alternativeLLCName1 %></td></tr>
                                <tr><th>Alternative 2</th><td><%= application.alternativeLLCName2 %></td></tr>
                                <tr><th>Business Purpose</th><td><%= application.businessPurpose.replace('_', ' ').toUpperCase() %></td></tr>
                                <% if (application.businessPurposeOther) { %>
                                <tr><th>Other Purpose</th><td><%= application.businessPurposeOther %></td></tr>
                                <% } %>
                            </table>
                        </div>

                        <!-- Business Address -->
                        <div class="detail-section">
                            <h3><i class="fas fa-map-marker-alt"></i> Business Address</h3>
                            <table class="detail-table">
                                <tr><th>Street</th><td><%= application.businessAddress?.street || 'N/A' %></td></tr>
                                <tr><th>City</th><td><%= application.businessAddress?.city || 'N/A' %></td></tr>
                                <tr><th>State</th><td><%= application.businessAddress?.state || 'N/A' %></td></tr>
                                <tr><th>ZIP Code</th><td><%= application.businessAddress?.zipCode || 'N/A' %></td></tr>
                                <tr><th>County</th><td><%= application.businessAddress?.county || 'Not specified' %></td></tr>
                            </table>
                        </div>

                        <!-- Registered Agent & Member -->
                        <div class="detail-section">
                            <h3><i class="fas fa-gavel"></i> Legal Details</h3>
                            <table class="detail-table">
                                <tr><th>Registered Agent</th><td><%= application.registeredAgent === 'zen_business' ? 'Zen Business (Included)' : 'Self' %></td></tr>
                                <tr><th>Member Name</th><td><%= application.memberName %></td></tr>
                                <tr><th>Ownership %</th><td><%= application.memberOwnership %>%</td></tr>
                                <tr><th>Member Address</th><td>
                                    <% if (application.memberAddress) { %>
                                        <%= application.memberAddress.street %>, <%= application.memberAddress.city %>, <%= application.memberAddress.state %> <%= application.memberAddress.zipCode %>
                                    <% } else { %>Same as business address<% } %>
                                </td></tr>
                            </table>
                        </div>

                        <!-- Plan & Payment -->
                        <div class="detail-section">
                            <h3><i class="fas fa-credit-card"></i> Plan & Payment</h3>
                            <table class="detail-table">
                                <tr><th>Selected Plan</th><td><%= application.planId?.name || 'N/A' %> ($<%= application.planId?.price || 0 %>)</td></tr>
                                <tr><th>Processing Time</th><td><%= application.planId?.processingTime || 'N/A' %></td></tr>
                                <tr><th>Payment Status</th><td><span class="badge badge-<%= application.paymentStatus %>"><%= application.paymentStatus %></span></td></tr>
                                <% if (application.paymentDate) { %>
                                <tr><th>Payment Date</th><td><%= application.paymentDate.toLocaleDateString() %></td></tr>
                                <% } %>
                                <% if (application.transactionId) { %>
                                <tr><th>Transaction ID</th><td><%= application.transactionId %></td></tr>
                                <% } %>
                            </table>
                        </div>

                        <!-- Documents -->
                        <div class="detail-section full-width">
                            <h3><i class="fas fa-file-upload"></i> Uploaded Documents</h3>
                            <% if (application.documents && application.documents.length > 0) { %>
                                <div class="document-grid">
                                    <% application.documents.forEach((doc, index) => { %>
                                        <div class="document-card">
                                            <% const ext = doc.fileName.split('.').pop().toLowerCase(); %>
                                            <% if (['jpg','jpeg','png','gif'].includes(ext)) { %>
                                                <img src="/admin/applications/document/<%= application._id %>/<%= index %>" alt="<%= doc.fileName %>">
                                            <% } else { %>
                                                <embed src="/admin/applications/document/<%= application._id %>/<%= index %>" width="100%" height="200px">
                                            <% } %>
                                            <div class="doc-label">
                                                <%= doc.fileName %>
                                                <a href="/admin/applications/document/<%= application._id %>/<%= index %>" target="_blank"><i class="fas fa-external-link-alt"></i></a>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <p class="text-muted">No documents uploaded.</p>
                            <% } %>
                        </div>

                        <!-- Timeline -->
                        <div class="detail-section full-width">
                            <h3><i class="fas fa-history"></i> Timeline</h3>
                            <table class="detail-table">
                                <tr><th>Created</th><td><%= application.createdAt.toLocaleString() %></td></tr>
                                <tr><th>Submitted</th><td><%= application.submittedAt ? application.submittedAt.toLocaleString() : 'Not submitted' %></td></tr>
                                <% if (application.approvedAt) { %>
                                <tr><th>Approved</th><td><%= application.approvedAt.toLocaleString() %></td></tr>
                                <% } %>
                                <% if (application.rejectedAt) { %>
                                <tr><th>Rejected</th><td><%= application.rejectedAt.toLocaleString() %></td></tr>
                                <tr><th>Rejection Reason</th><td><%= application.rejectionReason %></td></tr>
                                <% } %>
                            </table>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="action-bar">
                        <% if (application.status === 'pending') { %>
                            <form action="/admin/applications/<%= application._id %>/approve" method="POST" style="display:inline;">
                                <button type="submit" class="btn btn-success btn-lg approve-app">
                                    <i class="fas fa-check-circle"></i> Approve Application
                                </button>
                            </form>
                            <button type="button" class="btn btn-danger show-reject-modal"
                                    data-app-id="<%= application._id %>"
                                    data-llc-name="<%= application.desiredLLCName %>">
                                <i class="fas fa-times-circle"></i> Reject Application
                            </button>
                        <% } %>
                        <form action="/admin/applications/<%= application._id %>/delete" method="POST" style="display:inline;" class="delete-app-form">
                            <button type="submit" class="btn btn-sm btn-outline delete-app">
                                <i class="fas fa-trash"></i> Delete Application
                            </button>
                        </form>
                    </div>

                    <% if (application.adminNotes) { %>
                        <div class="admin-notes">
                            <h4>Admin Notes</h4>
                            <p><%= application.adminNotes %></p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Reject Modal -->
    <div id="rejectModal" class="modal" style="display:none;">
        <div class="modal-content">
            <h3>Reject Application</h3>
            <p>LLC: <span id="modalLLCName"></span></p>
            <form id="rejectForm" method="POST">
                <div class="form-group">
                    <label>Reason for rejection (will be emailed to user):</label>
                    <textarea name="rejectionReason" class="form-control" rows="4" required></textarea>
                </div>
                <div class="modal-actions">
                    <button type="submit" class="btn btn-danger">Confirm Reject</button>
                    <button type="button" class="btn btn-outline hide-reject-modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <script src="/js/main.js"></script>
    <script src="/js/admin-applications.js"></script>
</body>
</html>