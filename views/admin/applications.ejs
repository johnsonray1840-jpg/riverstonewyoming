<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/meta') %>
    <title>LLC Applications | Admin | River Stone Wyoming</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .filter-tabs { display: flex; gap: 10px; margin-bottom: 20px; }
        .filter-tab { padding: 8px 16px; background: var(--glass-bg); border-radius: 20px; color: var(--gray-light); text-decoration: none; }
        .filter-tab.active { background: var(--primary); color: white; }
        .badge-pending { background: rgba(245,158,11,0.2); color: var(--warning); }
        .badge-approved { background: rgba(16,185,129,0.2); color: var(--success); }
        .badge-rejected { background: rgba(239,68,68,0.2); color: var(--danger); }
        .btn-success { background: var(--success); color: white; }
        .modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 10000; }
        .modal-content { background: var(--secondary); padding: 30px; border-radius: 16px; max-width: 500px; width: 90%; }
        .modal-actions { display: flex; gap: 10px; margin-top: 20px; justify-content: flex-end; }
    </style>
</head>
<body>
    <%- include('../partials/header-admin') %>

    <div class="dashboard">
        <div class="container">
            <div class="dashboard-grid">
                <div class="sidebar">
                    <ul class="sidebar-nav">
                        <li><a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                        <li><a href="/admin/kyc"><i class="fas fa-id-card"></i> KYC Verification</a></li>
                        <li><a href="/admin/plans"><i class="fas fa-box"></i> Plans Management</a></li>
                        <li class="active"><a href="/admin/applications"><i class="fas fa-file-alt"></i> LLC Applications</a></li>
                        <li>
                            <a href="/admin/withdrawals">
                                <i class="fas fa-money-bill-wave"></i> 
                                Withdrawals
                            </a>
                        </li>
                        <li><a href="/admin/wallet-pool"><i class="fas fa-wallet"></i> Wallet Pool</a></li>
                        <li><a href="/admin/users"><i class="fas fa-users"></i> Users</a></li>
                    </ul>
                </div>

                <div class="content-area">
                    <div class="dashboard-header">
                        <h1>LLC Applications</h1>
                        <p>Review and manage submitted applications</p>
                    </div>

                    <% if (locals.success) { %>
                        <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
                    <% } %>
                    <% if (locals.error) { %>
                        <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
                    <% } %>

                    <!-- Filter tabs -->
                    <div class="filter-tabs">
                        <a href="/admin/applications" class="filter-tab <%= filter === 'all' ? 'active' : '' %>">All</a>
                        <a href="/admin/applications?status=pending" class="filter-tab <%= filter === 'pending' ? 'active' : '' %>">Pending</a>
                        <a href="/admin/applications?status=approved" class="filter-tab <%= filter === 'approved' ? 'active' : '' %>">Approved</a>
                        <a href="/admin/applications?status=rejected" class="filter-tab <%= filter === 'rejected' ? 'active' : '' %>">Rejected</a>
                    </div>

                    <div class="table-responsive">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Applicant</th>
                                    <th>LLC Name</th>
                                    <th>Plan</th>
                                    <th>Submitted</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (applications && applications.length > 0) { %>
                                    <% applications.forEach(app => { %>
                                        <tr>
                                            <td>
                                                <strong><%= app.userId?.fullName || 'N/A' %></strong><br>
                                                <small><%= app.userId?.email || '' %></small>
                                            </td>
                                            <td><%= app.desiredLLCName %></td>
                                            <td><%= app.planId?.name || 'N/A' %> ($<%= app.planId?.price || 0 %>)</td>
                                            <td><%= app.submittedAt ? app.submittedAt.toLocaleDateString() : 'Not submitted' %></td>
                                            <td>
                                                <span class="badge badge-<%= app.status %>"><%= app.status %></span>
                                            </td>
                                            <td>
                                                <div class="action-buttons">
                                                    <a href="/admin/applications/<%= app._id %>" class="btn btn-sm btn-outline">
                                                        <i class="fas fa-eye"></i> View
                                                    </a>
                                                    <% if (app.status === 'pending') { %>
                                                        <form action="/admin/applications/<%= app._id %>/approve" method="POST" style="display:inline;" class="approve-app-form">
                                                            <button type="submit" class="btn btn-sm btn-success approve-app">
                                                                <i class="fas fa-check"></i> Approve
                                                            </button>
                                                        </form>
                                                        <button type="button" class="btn btn-sm btn-danger show-reject-modal" 
                                                                data-app-id="<%= app._id %>" 
                                                                data-llc-name="<%= app.desiredLLCName %>">
                                                            <i class="fas fa-times"></i> Reject
                                                        </button>
                                                    <% } %>
                                                    <form action="/admin/applications/<%= app._id %>/delete" method="POST" style="display:inline;" class="delete-app-form">
                                                        <button type="submit" class="btn btn-sm btn-outline delete-app">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="6" style="text-align:center;padding:40px;">No applications found</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Reject Modal -->
    <div id="rejectModal" class="modal" style="display:none;">
        <div class="modal-content">
            <h3>Reject Application</h3>
            <p>LLC: <span id="modalLLCName"></span></p>
            <form id="rejectForm" method="POST">
                <div class="form-group">
                    <label>Reason for rejection (will be emailed to user):</label>
                    <textarea name="rejectionReason" class="form-control" rows="4" required></textarea>
                </div>
                <div class="modal-actions">
                    <button type="submit" class="btn btn-danger">Confirm Reject</button>
                    <button type="button" class="btn btn-outline hide-reject-modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <script src="/js/main.js"></script>
    <script src="/js/admin-applications.js"></script>
</body>
</html>