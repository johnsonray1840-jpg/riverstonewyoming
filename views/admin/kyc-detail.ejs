<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/meta') %>
    <title>KYC Detail | River Stone Wyoming</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .kyc-detail-container { max-width: 1200px; margin: 40px auto; }
        .profile-header { background: var(--card-bg); border-radius: 20px; padding: 30px; margin-bottom: 30px; border: 1px solid var(--glass-border); }
        .data-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 25px; margin-bottom: 30px; }
        .data-card { background: var(--card-bg); border: 1px solid var(--glass-border); border-radius: 16px; padding: 25px; }
        .data-card h3 { margin-bottom: 20px; }
        .data-table { width: 100%; }
        .data-table th { text-align: left; padding: 8px 0; color: var(--gray-light); width: 40%; font-weight: 500; }
        .document-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
        .document-card { background: var(--glass-bg); border-radius: 12px; overflow: hidden; border: 1px solid var(--glass-border); }
        .document-card img { width: 100%; height: 250px; object-fit: cover; display: block; }
        .document-card .doc-label { padding: 15px; text-align: center; font-weight: 500; }
        .action-bar { display: flex; gap: 15px; margin-top: 30px; flex-wrap: wrap; }
        .badge-large { font-size: 1rem; padding: 8px 20px; }
        .modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 1000; }
        .modal-content { background: var(--secondary); padding: 30px; border-radius: 20px; max-width: 500px; width: 90%; }
        .modal-content textarea { width: 100%; padding: 12px; background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 8px; color: white; resize: vertical; }
        .modal-actions { display: flex; gap: 10px; margin-top: 15px; justify-content: flex-end; }
    </style>
</head>
<body>
    <%- include('../partials/header-admin') %>
    <div class="kyc-detail-container container">
        <a href="/admin/kyc" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back to List</a>
        
        <div class="profile-header">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <h1><%= user.fullName %></h1>
                    <p style="color: var(--gray-light); margin: 5px 0 0;"><%= user.email %></p>
                </div>
                <span class="badge badge-<%= user.kycStatus %> badge-large"><%= user.kycStatus %></span>
            </div>
        </div>

        <div class="data-grid">
            <div class="data-card">
                <h3><i class="fas fa-user"></i> Personal Information</h3>
                <table class="data-table">
                    <tr><th>Full Name</th><td><%= user.fullName %></td></tr>
                    <tr><th>Date of Birth</th><td><%= user.kycData?.dateOfBirth?.toLocaleDateString() || '—' %></td></tr>
                    <tr><th>SSN (last 4)</th><td><%= user.kycData?.ssnLast4 || '—' %></td></tr>
                </table>
            </div>
            <div class="data-card">
                <h3><i class="fas fa-id-card"></i> ID Details</h3>
                <table class="data-table">
                    <tr><th>ID Type</th><td><%= user.kycData?.idType?.replace('_', ' ').toUpperCase() || '—' %></td></tr>
                    <tr><th>ID Number</th><td><%= user.kycData?.idNumber || '—' %></td></tr>
                    <tr><th>Address</th><td><%= user.kycData?.addressDetails?.street %>, <%= user.kycData?.addressDetails?.city %>, <%= user.kycData?.addressDetails?.state %> <%= user.kycData?.addressDetails?.zipCode %></td></tr>
                </table>
            </div>
        </div>

        <div class="data-card" style="margin-bottom: 20px;">
            <h3><i class="fas fa-images"></i> Uploaded Documents</h3>
            <div class="document-grid">
                <div class="document-card">
                    <% if (user.kycData?.idFrontImage) { %>
                        <img src="/admin/kyc/document/<%= user._id %>/idFrontImage" alt="ID Front">
                        <div class="doc-label">ID Front <a href="/admin/kyc/document/<%= user._id %>/idFrontImage" target="_blank"><i class="fas fa-external-link-alt"></i></a></div>
                    <% } else { %><div class="doc-label" style="padding: 40px; color: var(--gray);">Not uploaded</div><% } %>
                </div>
                <div class="document-card">
                    <% if (user.kycData?.idBackImage) { %>
                        <img src="/admin/kyc/document/<%= user._id %>/idBackImage" alt="ID Back">
                        <div class="doc-label">ID Back <a href="/admin/kyc/document/<%= user._id %>/idBackImage" target="_blank"><i class="fas fa-external-link-alt"></i></a></div>
                    <% } else { %><div class="doc-label" style="padding: 40px; color: var(--gray);">Not uploaded</div><% } %>
                </div>
                <div class="document-card">
                    <% if (user.kycData?.selfieImage) { %>
                        <img src="/admin/kyc/document/<%= user._id %>/selfieImage" alt="Selfie">
                        <div class="doc-label">Selfie with ID <a href="/admin/kyc/document/<%= user._id %>/selfieImage" target="_blank"><i class="fas fa-external-link-alt"></i></a></div>
                    <% } else { %><div class="doc-label" style="padding: 40px; color: var(--gray);">Not uploaded</div><% } %>
                </div>
                <div class="document-card">
                    <% if (user.kycData?.addressDocument) { %>
                        <% if (user.kycData.addressDocument.filePath.endsWith('.pdf')) { %>
                            <embed src="/admin/kyc/document/<%= user._id %>/addressDocument" width="100%" height="250px" style="display:block;">
                        <% } else { %>
                            <img src="/admin/kyc/document/<%= user._id %>/addressDocument" alt="Address Proof">
                        <% } %>
                        <div class="doc-label">Address Proof <a href="/admin/kyc/document/<%= user._id %>/addressDocument" target="_blank"><i class="fas fa-external-link-alt"></i></a></div>
                    <% } else { %><div class="doc-label" style="padding: 40px; color: var(--gray);">Not uploaded</div><% } %>
                </div>
            </div>
        </div>

        <% if (user.kycStatus === 'pending') { %>
            <div class="action-bar">
                <form action="/admin/kyc/<%= user._id %>/approve" method="POST">
                    <button type="submit" class="btn btn-success btn-lg"><i class="fas fa-check-circle"></i> Approve KYC</button>
                </form>
                <button id="showRejectBtn" class="btn btn-danger btn-lg"><i class="fas fa-times-circle"></i> Reject KYC</button>
                <form action="/admin/kyc/<%= user._id %>/delete" method="POST" id="deleteKycForm" style="display:inline;">
                    <button type="submit" id="deleteKycBtn" class="btn btn-outline btn-lg"><i class="fas fa-trash"></i> Delete KYC</button>
                </form>
            </div>
            <!-- Reject Modal -->
            <div id="rejectModal" class="modal" style="display:none;">
                <div class="modal-content">
                    <h3>Reject KYC</h3>
                    <form action="/admin/kyc/<%= user._id %>/reject" method="POST">
                        <textarea name="reason" placeholder="Reason for rejection (sent to user)" rows="4" required></textarea>
                        <div class="modal-actions">
                            <button type="submit" class="btn btn-danger">Confirm Reject</button>
                            <button type="button" id="hideRejectBtn" class="btn btn-outline">Cancel</button>
                        </div>
                    </form>
                </div>
            </div>
        <% } %>
        <% if (user.kycStatus !== 'pending') { %>
            <div class="action-bar">
                <form action="/admin/kyc/<%= user._id %>/delete" method="POST" onsubmit="return confirm('Delete this KYC? User will need to resubmit.');">
                    <button type="submit" class="btn btn-outline btn-lg"><i class="fas fa-trash"></i> Delete KYC</button>
                </form>
            </div>
        <% } %>
    </div>
    <script src="/js/admin-kyc.js"></script>
</body>
</html>
