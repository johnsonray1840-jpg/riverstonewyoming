<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/meta') %>
    <title>My LLCs | River Stone Wyoming</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .filter-tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 25px;
            flex-wrap: wrap;
        }
        .filter-tab {
            padding: 8px 20px;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 100px;
            color: var(--gray-light);
            text-decoration: none;
            font-size: 0.9rem;
            transition: all 0.2s;
            white-space: nowrap;
        }
        .filter-tab:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }
        .filter-tab.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }
        .info-box {
            background: rgba(6, 182, 212, 0.1);
            border: 1px solid var(--accent);
            border-radius: 12px;
            padding: 20px;
            display: flex;
            gap: 15px;
            align-items: flex-start;
            flex-wrap: wrap;
        }
        .info-box i {
            font-size: 1.5rem;
            color: var(--accent);
        }
        .info-box strong {
            color: var(--light);
        }
        .info-box p {
            color: var(--gray-light);
            margin: 5px 0 0;
            font-size: 0.9rem;
        }
        .badge-draft { background: rgba(100,116,139,0.2); color: var(--gray-light); }
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: var(--card-bg);
            border-radius: 16px;
            border: 1px dashed var(--glass-border);
        }
        .action-buttons {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        /* Sidebar toggle for mobile */
        .sidebar-toggle {
            display: none;
            width: 100%;
            padding: 12px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            margin-bottom: 20px;
        }
        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 9998;
        }
        .sidebar-overlay.open {
            display: block;
        }

        @media (max-width: 900px) {
            .sidebar-toggle {
                display: block;
            }
            .sidebar {
                position: fixed;
                top: 0;
                left: -100%;
                width: 280px;
                height: 100vh;
                z-index: 9999;
                border-radius: 0;
                transition: left 0.3s ease;
                overflow-y: auto;
            }
            .sidebar.open {
                left: 0;
            }
            .dashboard-header {
                flex-direction: column;
                align-items: flex-start !important;
                gap: 15px;
            }
            .dashboard-header .btn {
                width: 100%;
                justify-content: center;
            }
        }

        @media (max-width: 600px) {
            .filter-tab {
                padding: 6px 14px;
                font-size: 0.8rem;
            }
            .action-buttons .btn {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="dashboard">
        <div class="container">
            <!-- Mobile sidebar toggle -->
            <button class="sidebar-toggle" id="sidebarToggle">
                <i class="fas fa-bars"></i> Menu
            </button>
            <div class="sidebar-overlay" id="sidebarOverlay"></div>

            <div class="dashboard-grid">
                <!-- User Sidebar -->
                <div class="sidebar" id="sidebar">
                    <div class="user-profile">
                        <div class="user-avatar">
                            <i class="fas fa-user-circle"></i>
                        </div>
                        <h4><%= user.fullName %></h4>
                        <p><%= user.email %></p>
                    </div>
                    <ul class="sidebar-nav">
                        <li>
                            <a href="/user/dashboard">
                                <i class="fas fa-tachometer-alt"></i> Dashboard
                            </a>
                        </li>
                        <li>
                            <a href="/user/kyc">
                                <i class="fas fa-id-card"></i> Verification
                            </a>
                        </li>
                        <li class="active">
                            <a href="/user/llcs">
                                <i class="fas fa-building"></i> My LLCs
                            </a>
                        </li>
                        <li>
                            <a href="/user/wallet">
                                <i class="fas fa-wallet"></i> Wallet
                            </a>
                        </li>
                        <li>
                            <a href="/user/settings">
                                <i class="fas fa-cog"></i> Settings
                            </a>
                        </li>
                        <li>
                            <a href="/auth/logout">
                                <i class="fas fa-sign-out-alt"></i> Logout
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- Main Content -->
                <div class="content-area">
                    <div class="dashboard-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
                        <div>
                            <h1>My LLCs</h1>
                            <p>View and manage all your LLC applications and active entities</p>
                        </div>
                        <a href="/apply" class="btn btn-primary">
                            <i class="fas fa-plus"></i> New Application
                        </a>
                    </div>

                    <% if (locals.success) { %>
                        <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
                    <% } %>

                    <!-- Filter Tabs -->
                    <div class="filter-tabs">
                        <a href="/user/llcs" class="filter-tab <%= filter === 'all' ? 'active' : '' %>">All</a>
                        <a href="/user/llcs?status=pending" class="filter-tab <%= filter === 'pending' ? 'active' : '' %>">Pending</a>
                        <a href="/user/llcs?status=approved" class="filter-tab <%= filter === 'approved' ? 'active' : '' %>">Approved</a>
                        <a href="/user/llcs?status=rejected" class="filter-tab <%= filter === 'rejected' ? 'active' : '' %>">Rejected</a>
                    </div>

                    <% if (applications && applications.length > 0) { %>
                        <div class="table-responsive">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>LLC Name</th>
                                        <th>Plan</th>
                                        <th>Submitted</th>
                                        <th>Status</th>
                                        <th>State Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% applications.forEach(app => { %>
                                        <tr>
                                            <td>
                                                <strong><%= app.desiredLLCName %></strong>
                                                <% if (app.alternativeLLCName1) { %>
                                                    <br><small style="color: var(--gray-light);">Alt: <%= app.alternativeLLCName1 %></small>
                                                <% } %>
                                            </td>
                                            <td><%= app.planId?.name || 'N/A' %> ($<%= app.planId?.price || 0 %>)</td>
                                            <td><%= app.submittedAt ? app.submittedAt.toLocaleDateString() : 'Draft' %></td>
                                            <td>
                                                <span class="badge badge-<%= app.status %>"><%= app.status %></span>
                                            </td>
                                            <td>
                                                <% if (app.stateStatus) { %>
                                                    <span class="badge"><%= app.stateStatus %></span>
                                                <% } else { %>
                                                    —
                                                <% } %>
                                            </td>
                                            <td>
                                                <div class="action-buttons">
                                                    <a href="/user/llcs/<%= app._id %>" class="btn btn-sm btn-outline">
                                                        <i class="fas fa-eye"></i> View
                                                    </a>
                                                    <% if (app.status === 'approved' && !app.walletAssigned) { %>
                                                        <a href="/user/wallet/create?llc=<%= app._id %>" class="btn btn-sm btn-success">
                                                            <i class="fas fa-wallet"></i> Create Wallet
                                                        </a>
                                                    <% } %>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <div class="empty-state">
                            <i class="fas fa-building" style="font-size: 4rem; color: var(--gray); margin-bottom: 20px;"></i>
                            <h3>No LLC applications yet</h3>
                            <p>Get started by applying for your first crypto LLC.</p>
                            <a href="/apply" class="btn btn-primary btn-lg" style="margin-top: 20px;">
                                <i class="fas fa-rocket"></i> Apply for LLC
                            </a>
                        </div>
                    <% } %>

                    <!-- Information Box for Approved LLCs without Wallet -->
                    <% const approvedWithoutWallet = applications?.filter(a => a.status === 'approved' && !a.walletAssigned) || []; %>
                    <% if (approvedWithoutWallet.length > 0) { %>
                        <div class="info-box" style="margin-top: 30px;">
                            <i class="fas fa-info-circle"></i>
                            <div>
                                <strong>You have <%= approvedWithoutWallet.length %> approved LLC<%= approvedWithoutWallet.length > 1 ? 's' : '' %> ready for wallet creation.</strong>
                                <p>Click "Create Wallet" next to your approved LLC to claim your crypto wallet.</p>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
    <script src="/js/main.js"></script>
    <script>
        // Mobile sidebar toggle
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        const sidebarOverlay = document.getElementById('sidebarOverlay');

        if (sidebarToggle && sidebar && sidebarOverlay) {
            sidebarToggle.addEventListener('click', function() {
                sidebar.classList.add('open');
                sidebarOverlay.classList.add('open');
            });
            sidebarOverlay.addEventListener('click', function() {
                sidebar.classList.remove('open');
                sidebarOverlay.classList.remove('open');
            });
        }
    </script>
</body>
</html>