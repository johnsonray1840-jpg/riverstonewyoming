<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/meta') %>
    <title>My Wallet | River Stone Wyoming</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .chain-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin: 30px 0; }
        .chain-card { background: var(--card-bg); border: 1px solid var(--glass-border); border-radius: 16px; padding: 24px; text-align: center; }
        .chain-card h3 { margin-bottom: 15px; }
        .chain-address { font-family: monospace; background: var(--darker); padding: 10px; border-radius: 8px; word-break: break-all; font-size: 0.9rem; margin: 15px 0; }
        .qr-code { margin: 15px auto; display: block; max-width: 130px; border-radius: 8px; }
        .action-btns { display: flex; gap: 10px; justify-content: center; margin-top: 15px; }
        .receive-modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); display: flex; align-items: center; justify-content: center; z-index: 10000; }
        .receive-modal-content { background: var(--secondary); padding: 30px; border-radius: 20px; text-align: center; max-width: 400px; width: 90%; }
        .receive-modal-content .qr-large { max-width: 250px; margin: 20px auto; }
        .receive-modal-content .address-text { font-family: monospace; word-break: break-all; background: var(--darker); padding: 10px; border-radius: 8px; }
        .balance-line { margin: 10px 0; font-size: 0.95rem; }
        .balance-line .amount { font-weight: 600; }
        .total-balance-box { background: var(--card-bg); border: 1px solid var(--glass-border); border-radius: 16px; padding: 20px; text-align: center; margin-bottom: 25px; }
        .total-balance-amount { font-size: 2rem; font-weight: 700; color: var(--success); }
        .empty-state { text-align: center; padding: 60px 20px; }

        .success-popup {
    position: fixed;
    top: 20px;
    right: 20px;
    background: linear-gradient(135deg, var(--success), #059669);
    color: white;
    padding: 20px 30px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 15px;
    z-index: 10000;
    box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    animation: slideIn 0.3s ease-out;
    transition: opacity 0.5s;
}
.success-popup i {
    font-size: 2rem;
}
.success-popup strong {
    display: block;
    font-size: 1rem;
}
.success-popup p {
    margin: 0;
    font-size: 0.9rem;
    opacity: 0.9;
}
@keyframes slideIn {
    from { transform: translateX(100px); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
}
    </style>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="dashboard">
        <div class="container">
            <div class="dashboard-grid">
                <div class="sidebar">
                    <div class="user-profile">
                        <div class="user-avatar"><i class="fas fa-user-circle"></i></div>
                        <h4><%= user.fullName %></h4>
                        <p><%= user.email %></p>
                    </div>
                    <ul class="sidebar-nav">
                        <li><a href="/user/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                        <li><a href="/user/kyc"><i class="fas fa-id-card"></i> Verification</a></li>
                        <li><a href="/user/llcs"><i class="fas fa-building"></i> My LLCs</a></li>
                        <li class="active"><a href="/user/wallet"><i class="fas fa-wallet"></i> Wallet</a></li>
                        <li><a href="/user/settings"><i class="fas fa-cog"></i> Settings</a></li>
                        <li><a href="/auth/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                    </ul>
                </div>

                <div class="content-area">

                    <% if (locals.success) { %>
                        <div class="success-popup" id="successPopup">
                            <i class="fas fa-check-circle"></i>
                            <div>
                                <strong>Success!</strong>
                                <p><%= success %></p>
                            </div>
                        </div>
                        <script>
                            setTimeout(() => {
                                const popup = document.getElementById('successPopup');
                                if (popup) {
                                    popup.style.opacity = '0';
                                    setTimeout(() => popup.remove(), 500);
                                }
                            }, 5000);
                        </script>
                    <% } %>


                    <% if (!wallet) { %>
                        <div class="dashboard-header">
                            <h1>My Wallet</h1>
                            <p>You don't have a wallet yet.</p>
                        </div>
                        <div class="empty-state">
                            <i class="fas fa-wallet" style="font-size: 4rem; color: var(--gray); margin-bottom: 20px;"></i>
                            <h3>No Wallet Found</h3>
                            <p>You need an approved LLC to create a wallet.</p>
                            <% if (hasApprovedLLC) { %>
                                <a href="/user/wallet/create" class="btn btn-primary btn-lg" style="margin-top:20px;"><i class="fas fa-plus-circle"></i> Create Wallet</a>
                            <% } else { %>
                                <a href="/apply" class="btn btn-primary btn-lg" style="margin-top:20px;"><i class="fas fa-building"></i> Apply for LLC First</a>
                            <% } %>
                        </div>
                    <% } else { %>
                        <div class="dashboard-header">
                            <h1>My Crypto Wallet</h1>
                            <p>Linked to: <%= wallet.assignedLLCId?.desiredLLCName || 'Your LLC' %></p>
                        </div>

                        <!-- Total Balance -->
                        <div class="total-balance-box">
                            <div class="balance-label">Total Balance (USD)</div>
                            <div class="total-balance-amount">
                                <span class="balance-value">$<%= totalBalance.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></span>
                               <P>
                                <% if (locals.manualBalance && manualBalance !== 0) { %>
                                    <small style="color: var(--gray-light); display:block;">
                                        (includes $<%= manualBalance.toLocaleString() %> Profit made)
                                    </small>
                                <% } %>
                               </P>
                               <div style="text-align:center; margin-bottom:20px;">
                                <button class="btn btn-primary" id="showWithdrawModal"><i class="fas fa-arrow-up"></i> Withdraw</button>
                            </div>
                        </div>

                        <!-- Multi-Chain Cards -->
                        <div class="chain-grid">
                            <% const chains = ['btc','eth','usdt','xrp','bnb']; %>
                            <% chains.forEach(chain => { %>
                                <div class="chain-card">
                                    <h3><%= chain.toUpperCase() %></h3>
                                    <img src="<%= qrCodes[chain] %>" class="qr-code" alt="QR Code">
                                    <div class="chain-address"><%= wallet.addresses[chain] %></div>
                                    <a href="<%= getExplorerUrl(chain, wallet.addresses[chain]) %>" target="_blank" class="btn btn-sm btn-outline" style="margin-top:8px;">
                                        <i class="fas fa-external-link-alt"></i> View on Explorer
                                      </a>
                                    <div class="balance-line">
                                        <span class="amount"><%= chainBalances[chain].balance %></span> <%= chain.toUpperCase() %>
                                        (<span class="amount">$<%= chainBalances[chain].usdValue.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></span>)
                                    </div>
                                    <div class="action-btns">
                                        <button class="btn btn-sm btn-outline copy-btn" data-address="<%= wallet.addresses[chain] %>"><i class="fas fa-copy"></i> Copy</button>
                                        <button class="btn btn-sm btn-outline receive-btn" 
                                                data-chain="<%= chain.toUpperCase() %>" 
                                                data-address="<%= wallet.addresses[chain] %>"
                                                data-qr="<%= qrCodes[chain] %>">
                                            <i class="fas fa-qrcode"></i> Receive
                                        </button>
                                    </div>
                                </div>
                            <% }) %>
                        </div>

                        <!-- Security Notice -->
                        <div class="security-notice" style="margin-top:40px;">
                            <i class="fas fa-shield-alt"></i>
                            <div>
                                <strong>Non-Custodial Wallet</strong>
                                <p>Your 24‑word recovery phrase was displayed only once. We do not store it. Keep it safe.</p>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Withdraw Modal -->
<div id="withdrawModal" class="receive-modal" style="display:none;">
    <div class="receive-modal-content" style="max-width:500px;">
        <h3>Request Withdrawal</h3>
        <form action="/user/wallet/withdraw" method="POST">
            <div class="form-group">
                <label>Select Chain *</label>
                <select name="chain" class="form-control" required>
                    <option value="btc">BTC</option>
                    <option value="eth">ETH</option>
                    <option value="usdt">USDT</option>
                    <option value="xrp">XRP</option>
                    <option value="bnb">BNB</option>
                </select>
            </div>
            <div class="form-group">
                <label>Amount (USD) *</label>
                <input type="number" name="amount" class="form-control" step="0.01" min="0.01" required>
            </div>
            <div class="form-group">
                <label>Destination Address *</label>
                <input type="text" name="toAddress" class="form-control" required>
            </div>
            <div class="modal-actions">
                <button type="submit" class="btn btn-primary">Submit Request</button>
                <button type="button" class="btn btn-outline close-modal-btn">Cancel</button>
            </div>
        </form>
    </div>
</div>

    <!-- Receive Modal (same as before) -->
    <div id="receiveModal" class="receive-modal" style="display:none;">
        <div class="receive-modal-content">
            <h3 id="modalChain"></h3>
            <img id="modalQr" class="qr-large" src="" alt="QR Code">
            <p class="address-text" id="modalAddress"></p>
            <button class="btn btn-outline" id="closeReceiveModal">Close</button>
        </div>
    </div>

    <%- include('../partials/footer') %>
    <script src="/js/main.js"></script>
    <script src="/js/wallet.js"></script>

    <% if (!walletUnlocked && wallet) { %>
        <div id="pinOverlay" style="position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); display:flex; align-items:center; justify-content:center; z-index:9999;">
            <div style="background:var(--secondary); padding:30px; border-radius:20px; text-align:center; max-width:400px; width:90%;">
                <h3><i class="fas fa-lock"></i> Enter Wallet PIN</h3>
                <% if (locals.pinError) { %><div class="alert alert-error"><%= pinError %></div><% } %>
                <form method="POST" action="/user/wallet/unlock">
                    <input type="password" name="pin" class="form-control" placeholder="000000" maxlength="6" pattern="[0-9]{6}" required autofocus>
                    <button type="submit" class="btn btn-primary btn-block" style="margin-top:15px;">Unlock</button>
                </form>
            </div>
        </div>
        <% } %>
</body>
</html>