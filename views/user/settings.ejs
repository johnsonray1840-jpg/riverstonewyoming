<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/meta') %>
    <title>Settings | River Stone Wyoming</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('../partials/header') %>
    <div class="dashboard">
        <div class="container">
            <div class="dashboard-grid">
                <div class="sidebar">
                    <div class="user-profile">
                        <div class="user-avatar"><i class="fas fa-user-circle"></i></div>
                        <h4><%= user.fullName %></h4>
                        <p><%= user.email %></p>
                    </div>
                    <ul class="sidebar-nav">
                        <li><a href="/user/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                        <li>
                            <a href="/user/kyc">
                                <i class="fas fa-id-card"></i> Verification
                            </a>
                        </li>
                        <li><a href="/user/llcs"><i class="fas fa-building"></i> My LLCs</a></li>
                        <li><a href="/user/wallet"><i class="fas fa-wallet"></i> Wallet</a></li>
                        <li class="active"><a href="/user/settings"><i class="fas fa-cog"></i> Settings</a></li>
                        <li><a href="/auth/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                    </ul>
                </div>
                <div class="content-area">
                    <div class="dashboard-header">
                        <h1>Account Settings</h1>
                        <p>Manage your profile and security settings</p>
                    </div>
                    <% if (locals.success) { %><div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div><% } %>
                    <% if (locals.error) { %><div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div><% } %>
                    
                    <div class="settings-section">
                        <h3>Profile Information</h3>
                        <form action="/user/settings" method="POST">
                            <div class="form-group">
                                <label>Full Name</label>
                                <input type="text" name="fullName" class="form-control" value="<%= formData.fullName %>" required>
                            </div>
                            <div class="form-group">
                                <label>Email (cannot be changed)</label>
                                <input type="email" class="form-control" value="<%= user.email %>" disabled>
                            </div>
                            <div class="form-group">
                                <label>Phone</label>
                                <input type="text" name="phone" class="form-control" value="<%= formData.phone || '' %>">
                            </div>
                            <h4 style="margin-top: 30px;">Address</h4>
                            <div class="form-group">
                                <label>Street</label>
                                <input type="text" name="street" class="form-control" value="<%= formData.address?.street || '' %>">
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label>City</label>
                                    <input type="text" name="city" class="form-control" value="<%= formData.address?.city || '' %>">
                                </div>
                                <div class="form-group">
                                    <label>State</label>
                                    <input type="text" name="state" class="form-control" value="<%= formData.address?.state || '' %>">
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label>ZIP Code</label>
                                    <input type="text" name="zipCode" class="form-control" value="<%= formData.address?.zipCode || '' %>">
                                </div>
                                <div class="form-group">
                                    <label>Country</label>
                                    <input type="text" class="form-control" value="USA" disabled>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                        </form>
                    </div>
                    
                    <div class="settings-section">
                        <h3>Change Password</h3>
                        <form action="/user/settings/password" method="POST">
                            <div class="form-group">
                                <label>Current Password</label>
                                <input type="password" name="currentPassword" class="form-control" required>
                            </div>
                            <div class="form-group">
                                <label>New Password</label>
                                <input type="password" name="newPassword" class="form-control" required minlength="6">
                            </div>
                            <div class="form-group">
                                <label>Confirm New Password</label>
                                <input type="password" name="confirmPassword" class="form-control" required>
                            </div>
                            <button type="submit" class="btn btn-outline">Update Password</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <%- include('../partials/footer') %>
    <script src="/js/main.js"></script>
    <style>
        .settings-section { background: var(--card-bg); border: 1px solid var(--glass-border); border-radius: 12px; padding: 30px; margin-bottom: 30px; }
        .settings-section h3 { margin-bottom: 20px; }
        .settings-section h4 { margin-bottom: 15px; color: var(--gray-light); }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    </style>
</body>
</html>
