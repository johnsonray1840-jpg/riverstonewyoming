<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/meta') %>
    <title>LLC Details | River Stone Wyoming</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('../partials/header') %>

    <div class="dashboard">
        <div class="container">
            <div class="dashboard-grid">
                <!-- User Sidebar -->
                <div class="sidebar">
                    <div class="user-profile">
                        <div class="user-avatar">
                            <i class="fas fa-user-circle"></i>
                        </div>
                        <h4><%= user.fullName %></h4>
                        <p><%= user.email %></p>
                    </div>
                    <ul class="sidebar-nav">
                        <li>
                            <a href="/user/dashboard">
                                <i class="fas fa-tachometer-alt"></i> Dashboard
                            </a>
                        </li>
                        <li class="active">
                            <a href="/user/llcs">
                                <i class="fas fa-building"></i> My LLCs
                            </a>
                        </li>
                        <li>
                            <a href="/user/wallet">
                                <i class="fas fa-wallet"></i> Wallet
                            </a>
                        </li>
                        <li>
                            <a href="/user/settings">
                                <i class="fas fa-cog"></i> Settings
                            </a>
                        </li>
                        <li>
                            <a href="/auth/logout">
                                <i class="fas fa-sign-out-alt"></i> Logout
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- Main Content -->
                <div class="content-area">
                    <div class="dashboard-header">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                            <div>
                                <a href="/user/llcs" class="back-link">
                                    <i class="fas fa-arrow-left"></i> Back to My LLCs
                                </a>
                                <h1 style="margin-top: 10px;"><%= application.desiredLLCName %></h1>
                                <div style="display: flex; gap: 15px; align-items: center;">
                                    <span class="badge badge-<%= application.status %>" style="font-size: 1rem;"><%= application.status %></span>
                                    <% if (application.stateStatus) { %>
                                        <span class="badge"><%= application.stateStatus %></span>
                                    <% } %>
                                </div>
                            </div>
                            <div>
                                <% if (application.status === 'approved' && !locals.walletAssigned) { %>
                                    <a href="/user/wallet/create?llc=<%= application._id %>" class="btn btn-success btn-lg">
                                        <i class="fas fa-wallet"></i> Create Wallet
                                    </a>
                                <% } else if (application.status === 'incomplete') { %>
                                    <a href="/apply/continue/<%= application._id %>" class="btn btn-primary btn-lg">
                                        <i class="fas fa-pen"></i> Continue Application
                                    </a>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <!-- Status Timeline -->
                    <div class="status-timeline">
                        <div class="timeline-step <%= application.status !== 'incomplete' ? 'completed' : '' %>">
                            <div class="step-icon"><i class="fas fa-file-signature"></i></div>
                            <div class="step-label">Application Started</div>
                            <div class="step-date"><%= application.createdAt.toLocaleDateString() %></div>
                        </div>
                        <div class="timeline-connector <%= application.submittedAt ? 'completed' : '' %>"></div>
                        <div class="timeline-step <%= application.submittedAt ? 'completed' : '' %>">
                            <div class="step-icon"><i class="fas fa-paper-plane"></i></div>
                            <div class="step-label">Submitted</div>
                            <div class="step-date"><%= application.submittedAt ? application.submittedAt.toLocaleDateString() : '—' %></div>
                        </div>
                        <div class="timeline-connector <%= application.approvedAt ? 'completed' : '' %>"></div>
                        <div class="timeline-step <%= application.approvedAt ? 'completed' : '' %>">
                            <div class="step-icon"><i class="fas fa-check-circle"></i></div>
                            <div class="step-label">Approved</div>
                            <div class="step-date"><%= application.approvedAt ? application.approvedAt.toLocaleDateString() : '—' %></div>
                        </div>
                    </div>

                    <div class="detail-grid">
                        <!-- LLC Information -->
                        <div class="detail-section">
                            <h3><i class="fas fa-building"></i> LLC Information</h3>
                            <table class="detail-table">
                                <tr><th>Desired Name</th><td><strong><%= application.desiredLLCName %></strong></td></tr>
                                <tr><th>Alternative 1</th><td><%= application.alternativeLLCName1 %></td></tr>
                                <tr><th>Alternative 2</th><td><%= application.alternativeLLCName2 %></td></tr>
                                <tr><th>Business Purpose</th><td><%= application.businessPurpose.replace('_', ' ').toUpperCase() %></td></tr>
                                <% if (application.businessPurposeOther) { %>
                                <tr><th>Other</th><td><%= application.businessPurposeOther %></td></tr>
                                <% } %>
                            </table>
                        </div>

                        <!-- Business Address -->
                        <div class="detail-section">
                            <h3><i class="fas fa-map-marker-alt"></i> Business Address</h3>
                            <table class="detail-table">
                                <tr><th>Street</th><td><%= application.businessAddress?.street || '—' %></td></tr>
                                <tr><th>City</th><td><%= application.businessAddress?.city || '—' %></td></tr>
                                <tr><th>State</th><td><%= application.businessAddress?.state || '—' %></td></tr>
                                <tr><th>ZIP Code</th><td><%= application.businessAddress?.zipCode || '—' %></td></tr>
                            </table>
                        </div>

                        <!-- Registered Agent & Member -->
                        <div class="detail-section">
                            <h3><i class="fas fa-user-tie"></i> Member Information</h3>
                            <table class="detail-table">
                                <tr><th>Member Name</th><td><%= application.memberName %></td></tr>
                                <tr><th>Ownership</th><td><%= application.memberOwnership %>%</td></tr>
                                <tr><th>Registered Agent</th><td><%= application.registeredAgent === 'zen_business' ? 'Zen Business' : 'Self' %></td></tr>
                            </table>
                        </div>

                        <!-- Plan & Payment -->
                        <div class="detail-section">
                            <h3><i class="fas fa-credit-card"></i> Plan & Payment</h3>
                            <table class="detail-table">
                                <tr><th>Plan</th><td><%= application.planId?.name %> ($<%= application.planId?.price %>)</td></tr>
                                <tr><th>Processing Time</th><td><%= application.planId?.processingTime %></td></tr>
                                <tr><th>Payment Status</th><td><span class="badge badge-<%= application.paymentStatus %>"><%= application.paymentStatus %></span></td></tr>
                                <% if (application.paymentDate) { %>
                                <tr><th>Payment Date</th><td><%= application.paymentDate.toLocaleDateString() %></td></tr>
                                <% } %>
                            </table>
                        </div>

                        <!-- Documents -->
                        <div class="detail-section full-width">
                            <h3><i class="fas fa-file-upload"></i> Documents</h3>
                            <% if (application.documents && application.documents.length > 0) { %>
                                <ul class="document-list">
                                    <% application.documents.forEach(doc => { %>
                                        <li>
                                            <i class="fas fa-file-pdf"></i>
                                            <span><%= doc.fileName %></span>
                                            <small><%= doc.uploadedAt.toLocaleDateString() %></small>
                                        </li>
                                    <% }) %>
                                </ul>
                            <% } else { %>
                                <p class="text-muted">No documents uploaded.</p>
                            <% } %>
                        </div>

                        <!-- Rejection Reason (if rejected) -->
                        <% if (application.status === 'rejected' && application.rejectionReason) { %>
                        <div class="detail-section full-width" style="border-color: var(--danger);">
                            <h3 style="color: var(--danger);"><i class="fas fa-exclamation-triangle"></i> Rejection Reason</h3>
                            <p><%= application.rejectionReason %></p>
                            <a href="/apply/resubmit/<%= application._id %>" class="btn btn-primary" style="margin-top: 15px;">
                                <i class="fas fa-redo"></i> Resubmit Application
                            </a>
                        </div>
                        <% } %>

                        <!-- Admin Notes (if any and approved) -->
                        <% if (application.adminNotes && application.status === 'approved') { %>
                        <div class="detail-section full-width">
                            <h3><i class="fas fa-clipboard"></i> Notes from Admin</h3>
                            <p><%= application.adminNotes %></p>
                        </div>
                        <% } %>
                    </div>

                    <!-- Wallet Assignment Info -->
                    <% if (locals.walletAssigned) { %>
                        <div class="wallet-card">
                            <i class="fas fa-check-circle" style="color: var(--success); font-size: 1.5rem;"></i>
                            <div>
                                <strong>Wallet Created</strong>
                                <p>A crypto wallet has been assigned to this LLC. <a href="/user/wallet">View Wallet</a></p>
                            </div>
                        </div>
                    <% } else if (application.status === 'approved') { %>
                        <div class="wallet-card">
                            <i class="fas fa-wallet" style="color: var(--primary); font-size: 1.5rem;"></i>
                            <div>
                                <strong>Ready for Wallet Creation</strong>
                                <p>Your LLC is approved! Create your non-custodial wallet now to manage crypto assets.</p>
                                <a href="/user/wallet/create?llc=<%= application._id %>" class="btn btn-success">Create Wallet</a>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
    <script src="/js/main.js"></script>
    <style>
        .back-link {
            color: var(--gray-light);
            text-decoration: none;
            font-size: 0.9rem;
        }
        .back-link:hover {
            color: var(--primary);
        }
        .status-timeline {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin: 30px 0;
            padding: 20px;
            background: var(--card-bg);
            border-radius: 12px;
        }
        .timeline-step {
            text-align: center;
            flex: 1;
        }
        .timeline-step .step-icon {
            width: 40px;
            height: 40px;
            margin: 0 auto 10px;
            background: var(--glass-bg);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--gray-light);
        }
        .timeline-step.completed .step-icon {
            background: var(--success);
            color: white;
        }
        .timeline-connector {
            width: 60px;
            height: 2px;
            background: var(--glass-border);
        }
        .timeline-connector.completed {
            background: var(--success);
        }
        .step-label {
            font-weight: 500;
            margin-bottom: 4px;
        }
        .step-date {
            font-size: 0.8rem;
            color: var(--gray-light);
        }
        .detail-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin: 20px 0;
        }
        .detail-section {
            background: var(--card-bg);
            border: 1px solid var(--glass-border);
            border-radius: 12px;
            padding: 20px;
        }
        .detail-section.full-width {
            grid-column: span 2;
        }
        .detail-section h3 {
            margin-bottom: 15px;
            font-size: 1.1rem;
        }
        .detail-table {
            width: 100%;
        }
        .detail-table th {
            text-align: left;
            width: 40%;
            color: var(--gray-light);
            font-weight: 500;
            padding: 8px 0;
        }
        .document-list {
            list-style: none;
        }
        .document-list li {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 0;
            border-bottom: 1px solid var(--glass-border);
        }
        .document-list li:last-child {
            border-bottom: none;
        }
        .wallet-card {
            margin-top: 30px;
            padding: 20px;
            background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(6,182,212,0.1));
            border: 1px solid var(--primary);
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 20px;
        }
        @media (max-width: 768px) {
            .detail-grid {
                grid-template-columns: 1fr;
            }
            .detail-section.full-width {
                grid-column: span 1;
            }
            .status-timeline {
                flex-direction: column;
                gap: 15px;
            }
            .timeline-connector {
                width: 2px;
                height: 30px;
            }
        }
    </style>
</body>
</html>
